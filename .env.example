# Supabase Configuration

# Get these values from your Supabase project settings:
# https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Copy this file to .env.local (do not commit .env.local)
# 2. Replace the placeholder values with your actual Supabase credentials
# 3. You can find these values in your Supabase dashboard:
#    - Project URL: Settings > API > Project URL
#    - Anon Key: Settings > API > Project API keys > anon (public)
# 4. For production, set these environment variables in your hosting platform
#    (Vercel, Netlify, etc.) instead of using .env.local
